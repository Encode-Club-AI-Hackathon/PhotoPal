.webview-page {
  width: 100%;
  height: 100vh;
  position: relative;
}

.empty {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: #0a111d;
}

.loading-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 17, 29, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.spinner {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  border: 3rpx solid #6685b8;
  border-top-color: #eef6ff;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #d2e1fb;
}

.empty-card {
  width: 100%;
  border-radius: 18rpx;
  border: 1rpx solid #385477;
  background: #111c2e;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8f1ff;
}

.empty-text {
  color: #b6c8e7;
  font-size: 24rpx;
  line-height: 1.45;
}

.retry-btn,
.back-btn {
  width: 100%;
  margin: 0;
  border-radius: 12rpx;
}

.retry-btn {
  background: #2f548f;
  color: #f2f8ff;
}

.back-btn {
  background: #1a2c44;
  color: #d8e6ff;
  border: 1rpx solid #3f5f86;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
