.settings-page {
  min-height: 100vh;
  width: 100%;
  padding: 56rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, #fff8ef 0%, #f4f7ff 100%);
}

.settings-card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(20, 28, 40, 0.08);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.settings-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #182033;
}

.settings-subtitle {
  font-size: 26rpx;
  color: #44516a;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.settings-item {
  width: 100%;
  margin: 0;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 2rpx solid #d7deec;
  background: #ffffff;
  color: #13294b;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-label {
  font-size: 28rpx;
  font-weight: 600;
}

.item-arrow {
  font-size: 34rpx;
  color: #66758f;
}
