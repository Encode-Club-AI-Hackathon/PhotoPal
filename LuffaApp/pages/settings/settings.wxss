.settings-page {
  min-height: 100vh;
  width: 100%;
  padding: 42rpx 24rpx 56rpx;
  box-sizing: border-box;
  background: #0a111d;
  position: relative;
  overflow: hidden;
}

button::after {
  border: none;
}

.settings-card {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #111c2e;
  border: 1rpx solid #31496a;
  box-shadow: 0 12rpx 28rpx rgba(1, 6, 14, 0.5);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.settings-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #eaf2ff;
}

.settings-subtitle {
  font-size: 24rpx;
  color: #b5c8e7;
  line-height: 1.45;
  margin-bottom: 8rpx;
}

.loading-card,
.status-card,
.error-card {
  border-radius: 12rpx;
  padding: 14rpx;
}

.loading-card {
  border: 1rpx solid #36567a;
  background: #112135;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.spinner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 999rpx;
  border: 3rpx solid #6283b7;
  border-top-color: #ecf4ff;
  animation: spin 0.85s linear infinite;
}

.loading-text {
  font-size: 21rpx;
  color: #c6d8f4;
}

.status-card {
  border: 1rpx solid #2f6a79;
  background: #12303f;
}

.status-text {
  font-size: 21rpx;
  color: #baecf6;
}

.error-card {
  border: 1rpx solid #7a353d;
  background: #35171c;
}

.error-text {
  font-size: 21rpx;
  color: #f8cbd1;
}

.settings-item {
  width: 100%;
  margin: 0;
  padding: 0 22rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 14rpx;
  border: 1rpx solid #40658f;
  background: #1a2d45;
  color: #d8e7ff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.item-label {
  font-size: 26rpx;
  font-weight: 600;
}

.item-arrow {
  font-size: 34rpx;
  color: #aec5ea;
}

.wallet-card {
  margin-top: 6rpx;
  width: 100%;
  border-radius: 16rpx;
  border: 1rpx solid #3c5b82;
  background: #132236;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.wallet-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.wallet-head-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.wallet-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #edf4ff;
}

.wallet-status {
  font-size: 21rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  max-width: max-content;
  align-self: flex-start;
}

.wallet-status-on {
  background: #205947;
  color: #d8fcec;
  border-color: #2f7d67;
}

.wallet-status-off {
  background: #4a3746;
  color: #f8d5e6;
  border-color: #734f67;
}

.wallet-avatar,
.wallet-avatar-fallback {
  width: 90rpx;
  height: 90rpx;
  border-radius: 45rpx;
  border: 1rpx solid #4a678f;
}

.wallet-avatar-fallback {
  background: #223750;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wallet-avatar-fallback-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #d5e4ff;
}

.wallet-head-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  align-items: flex-start;
}

.wallet-details {
  width: 100%;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.wallet-detail-item {
  width: calc(50% - 5rpx);
  min-width: 0;
  padding: 2rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wallet-detail-label {
  font-size: 20rpx;
  color: #9eb6dc;
}

.wallet-detail-value {
  font-size: 22rpx;
  color: #e6efff;
  word-break: break-all;
}

.wallet-address-item {
  width: 100%;
  margin-top: 4rpx;
}

.wallet-address {
  font-size: 22rpx;
  color: #d2e1fb;
  word-break: break-all;
}

.wallet-btn {
  width: 100%;
  margin: 0;
  border-radius: 14rpx;
}

.wallet-connect {
  background: #2f548f;
  color: #f4f9ff;
}

.wallet-disconnect {
  background: #5b2f39;
  color: #ffdbe6;
  border: 1rpx solid #7a4452;
  font-size: 24rpx;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
