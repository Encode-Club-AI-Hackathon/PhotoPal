.settings-page {
  min-height: 100vh;
  width: 100%;
  padding: 56rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, #fff8ef 0%, #f4f7ff 100%);
}

.settings-card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(20, 28, 40, 0.08);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.settings-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #182033;
}

.settings-subtitle {
  font-size: 26rpx;
  color: #44516a;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.settings-item {
  width: 100%;
  margin: 0;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 2rpx solid #d7deec;
  background: #ffffff;
  color: #13294b;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.item-label {
  font-size: 28rpx;
  font-weight: 600;
}

.item-arrow {
  font-size: 34rpx;
  color: #66758f;
}

.wallet-card {
  margin-top: 8rpx;
  width: 100%;
  border-radius: 16rpx;
  border: 2rpx solid #d7deec;
  background: #f8fbff;
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.wallet-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.wallet-head-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.wallet-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #182033;
}

.wallet-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  max-width: max-content;
  align-self: flex-start;
}

.wallet-status-on {
  background: #e9f9ef;
  color: #1d6b3b;
  border-color: #a9dfba;
}

.wallet-status-off {
  background: #f1f5f9;
  color: #475569;
  border-color: #cbd5e1;
}

.wallet-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  border: 2rpx solid #d7deec;
}

.wallet-avatar-fallback {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  border: 2rpx solid #d7deec;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wallet-avatar-fallback-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #475569;
}

.wallet-head-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  align-items: flex-start;
}

.wallet-details {
  width: 100%;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.wallet-detail-item {
  width: calc(50% - 5rpx);
  min-width: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 2rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wallet-detail-label {
  font-size: 20rpx;
  color: #64748b;
}

.wallet-detail-value {
  font-size: 22rpx;
  color: #1e293b;
  word-break: break-all;
}

.wallet-address-item {
  width: 100%;
  margin-top: 4rpx;
}

.wallet-address {
  font-size: 22rpx;
  color: #4d5b74;
  word-break: break-all;
}

.wallet-btn {
  width: 100%;
  margin: 0;
  border-radius: 14rpx;
}

.wallet-connect {
  background: #13294b;
  color: #ffffff;
}

.wallet-disconnect {
  background: #fff1f2;
  color: #b42318;
  border: 2rpx solid #fda4af;
  font-size: 24rpx;
}
