.page {
  min-height: 100vh;
  padding: 44rpx 24rpx 56rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: #0a111d;
  position: relative;
  overflow: hidden;
}

button::after {
  border: none;
}

.status-card,
.loading-card,
.error-card,
.card,
.empty-card {
  position: relative;
  z-index: 1;
}

.status-card {
  border-radius: 14rpx;
  border: 1rpx solid #2f6a78;
  background: #11303f;
  padding: 16rpx;
}

.status-text {
  font-size: 22rpx;
  color: #b8ecf5;
}

.loading-card {
  border-radius: 14rpx;
  border: 1rpx solid #365679;
  background: #112135;
  padding: 18rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.spinner {
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  border: 3rpx solid #6484b8;
  border-top-color: #ebf5ff;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  font-size: 23rpx;
  color: #c4d6f2;
}

.error-card {
  border-radius: 14rpx;
  border: 1rpx solid #79363e;
  background: #34171c;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.error-text {
  font-size: 22rpx;
  color: #f6ccd2;
}

.card,
.empty-card {
  width: 100%;
  padding: 26rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #111c2e;
  border: 1rpx solid #2f496b;
  box-shadow: 0 12rpx 28rpx rgba(1, 6, 14, 0.5);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e9f1ff;
}

.empty-subtitle {
  font-size: 24rpx;
  line-height: 1.45;
  color: #b6c8e7;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8f1ff;
}

.primary-btn,
.secondary-btn,
.secondary-button {
  border-radius: 14rpx;
}

.primary-btn {
  width: 100%;
  margin: 0;
  font-size: 24rpx;
  background: #2e548e;
  color: #f5f9ff;
}

.secondary-btn {
  width: 100%;
  margin: 0;
  font-size: 24rpx;
  background: #1a2c44;
  border: 1rpx solid #3b5d84;
  color: #d4e3fb;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #2a415f;
}

.kv-stack-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #2a415f;
}

.kv-stack-label {
  text-align: left;
}

.kv-stack-value {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.kv-key {
  font-size: 24rpx;
  color: #9bb2d7;
}

.kv-value {
  flex: 1;
  font-size: 24rpx;
  color: #e8f1ff;
  word-break: break-all;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.kv-value text {
  text-align: right;
}

.button-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.refresh-row {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.secondary-button {
  width: 100%;
  margin: 0;
  background: #223b5e;
  border: 1rpx solid #4a6f9a;
  color: #e3eeff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-row-btn {
  width: 100%;
}

.button-half {
  flex: 1;
  height: 84rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-yes {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: #235947;
  color: #d8fdec;
  font-weight: 600;
  font-size: 23rpx;
}

.tag-no {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: #5b2f3a;
  color: #ffdbe7;
  font-weight: 600;
  font-size: 23rpx;
}

.tags-container {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-start;
}

.tag-primary-niche {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #2c4f87;
  color: #f3f8ff;
  font-weight: 600;
  font-size: 23rpx;
}

.tag-secondary-niche {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #203349;
  color: #c6d8f4;
  font-weight: 600;
  font-size: 23rpx;
}

.instagram-link,
.email-link {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.instagram-link {
  border: 1rpx solid #6b4870;
  background: #2b1e32;
}

.instagram-icon,
.email-icon {
  width: 28rpx;
  height: 28rpx;
}

.instagram-handle {
  color: #f0ccff;
  font-weight: 600;
}

.email-link {
  border: 1rpx solid #426180;
  background: #15283e;
}

.email-text {
  color: #d9e7ff;
  font-weight: 600;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
