.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  background: linear-gradient(155deg, #f8fbff 0%, #f3f7ff 50%, #fff9f1 100%);
}

.hero-card,
.card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(16, 24, 40, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 46rpx;
  font-weight: 700;
  color: #182033;
}

.subtitle {
  font-size: 28rpx;
  line-height: 1.5;
  color: #4a5770;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #182033;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.primary-btn,
.secondary-btn {
  border-radius: 14rpx;
}

.primary-btn {
  width: 100%;
  margin: 0;
  font-size: 24rpx;
  background: #0f2a57;
  color: #ffffff;
}

.secondary-btn {
  width: 100%;
  margin: 0;
  font-size: 24rpx;
  background: #ffffff;
  border: 2rpx solid #0f2a57;
  color: #0f2a57;
}

.error-text {
  font-size: 24rpx;
  color: #b42318;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf1f6;
}

.kv-stack-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf1f6;
}

.kv-stack-label {
  text-align: left;
}

.kv-stack-value {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.kv-key {
  font-size: 26rpx;
  color: #475467;
}

.kv-value {
  flex: 1;
  font-size: 26rpx;
  color: #182033;
  word-break: break-all;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.kv-value text {
  text-align: right;
}

.button-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 14rpx;
}

.refresh-row {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.secondary-button {
  width: 100%;
  margin: 0;
  border-radius: 16rpx;
  background: #13294b;
  border: 2rpx solid #13294b;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-row-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.button-half {
  flex: 1;
  height: 84rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-yes {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: #e9f9ef;
  color: #1d6b3b;
  font-weight: 600;
  font-size: 24rpx;
  border: 1rpx solid #a9dfba;
}

.tag-no {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: #fff1f2;
  color: #b42318;
  font-weight: 600;
  font-size: 24rpx;
  border: 1rpx solid #fda4af;
}

.tags-container {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-start;
}

.tag-primary-niche {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #13294b;
  color: #ffffff;
  font-weight: 600;
  font-size: 24rpx;
  border: 1rpx solid #0f2a57;
}

.tag-secondary-niche {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #475569;
  font-weight: 600;
  font-size: 24rpx;
  border: 1rpx solid #cbd5e1;
}

.instagram-link {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #f1d2e8;
  background: #fff5fb;
}

.instagram-icon {
  width: 30rpx;
  height: 30rpx;
}

.instagram-handle {
  color: #c13584;
  font-weight: 600;
}

.email-link {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #000000;
  background: #ffffff;
}

.email-icon {
  width: 30rpx;
  height: 30rpx;
  filter: grayscale(100%);
}

.email-text {
  color: #111111;
  font-weight: 600;
}
