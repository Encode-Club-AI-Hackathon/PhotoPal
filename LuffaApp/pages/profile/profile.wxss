.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
}

.subtitle {
  font-size: 28rpx;
  line-height: 1.5;
}
