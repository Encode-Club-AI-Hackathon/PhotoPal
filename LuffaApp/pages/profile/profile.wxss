.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  background: linear-gradient(155deg, #f8fbff 0%, #f3f7ff 50%, #fff9f1 100%);
}

.hero-card,
.card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(16, 24, 40, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 46rpx;
  font-weight: 700;
  color: #182033;
}

.subtitle {
  font-size: 28rpx;
  line-height: 1.5;
  color: #4a5770;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #182033;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.primary-btn,
.secondary-btn {
  border-radius: 14rpx;
}

.primary-btn {
  width: 100%;
  margin: 0;
  background: #0f2a57;
  color: #ffffff;
}

.secondary-btn {
  width: 100%;
  margin: 0;
  background: #ffffff;
  border: 2rpx solid #0f2a57;
  color: #0f2a57;
}

.error-text {
  font-size: 24rpx;
  color: #b42318;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf1f6;
}

.kv-key {
  font-size: 26rpx;
  color: #475467;
}

.kv-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #182033;
  word-break: break-all;
}

.button-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 14rpx;
}

.button-half {
  flex: 1;
  height: 84rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
