<view class="container page">
  <view class="hero-card">
    <text class="title">My Photographer Profile</text>
    <text class="subtitle">Synced from photographer_profiles using your wallet UID.</text>
    <button class="primary-btn" bindtap="refreshProfileData" loading="{{loadingProfile}}" disabled="{{loadingProfile}}">Refresh Profile</button>
    <text class="error-text" wx:if="{{profileError}}">{{profileError}}</text>
  </view>

  <view class="card">
    <text class="section-title">Wallet</text>
    <view class="kv-row"><text class="kv-key">Connected</text><text class="kv-value">{{walletConnected ? 'Yes' : 'No'}}</text></view>
    <view class="kv-row"><text class="kv-key">UID</text><text class="kv-value">{{walletUid || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Address</text><text class="kv-value">{{walletAddress || '-'}}</text></view>
  </view>

  <view class="card" wx:if="{{hasPhotographerProfile && photographerProfile}}">
    <text class="section-title">Photographer Details</text>
    <view class="kv-row"><text class="kv-key">Name</text><text class="kv-value">{{photographerProfile.name || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Primary Niche</text><text class="kv-value">{{photographerProfile.primaryNiche || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Secondary Niches</text><text class="kv-value">{{photographerProfile.secondaryNiches || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Email</text><text class="kv-value">{{photographerProfile.contactEmail || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Instagram</text><text class="kv-value">{{photographerProfile.instagramHandle || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">City</text><text class="kv-value">{{photographerProfile.locationCity || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Country</text><text class="kv-value">{{photographerProfile.locationCountry || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Human Presence</text><text class="kv-value">{{photographerProfile.humanPresence || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Willing to Travel</text><text class="kv-value">{{photographerProfile.willingnessToTravel || '-'}}</text></view>
    <view class="kv-row"><text class="kv-key">Studio Access</text><text class="kv-value">{{photographerProfile.studioAccess || '-'}}</text></view>

    <button class="secondary-btn" wx:if="{{photographerProfile.websiteUrl}}" bindtap="openWebsite">Open Portfolio</button>
  </view>
</view>
