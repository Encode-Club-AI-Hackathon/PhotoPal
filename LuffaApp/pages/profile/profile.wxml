<view class="container page">
  <view class="card" wx:if="{{hasPhotographerProfile && photographerProfile}}">
    <text class="section-title">Photographer Details</text>
    <view class="kv-row"><text class="kv-key">Name</text><view class="kv-value"><text>{{photographerProfile.name || '-'}}</text></view></view>
    <view class="kv-stack-row">
      <text class="kv-key kv-stack-label">Primary Niche</text>
      <view class="kv-stack-value">
        <text class="tag-primary-niche" wx:if="{{photographerProfile.primaryNiche}}">{{photographerProfile.primaryNiche}}</text>
        <text wx:else>-</text>
      </view>
    </view>
    <view class="kv-stack-row">
      <text class="kv-key kv-stack-label">Secondary Niches</text>
      <view class="kv-stack-value tags-container">
        <text class="tag-secondary-niche" wx:for="{{photographerProfile.secondaryNichesList}}" wx:key="*this">{{item}}</text>
        <text wx:if="{{!photographerProfile.secondaryNichesList || photographerProfile.secondaryNichesList.length === 0}}">-</text>
      </view>
    </view>
    <view class="kv-row">
      <text class="kv-key">Email</text>
      <view class="kv-value">
        <view class="email-link" wx:if="{{photographerProfile.contactEmail}}" bindtap="openEmail">
          <image class="email-icon" src="{{emailIcon}}" mode="aspectFit"></image>
          <text class="email-text">{{photographerProfile.contactEmail}}</text>
        </view>
        <text wx:else>-</text>
      </view>
    </view>
    <view class="kv-row">
      <text class="kv-key">Instagram</text>
      <view class="kv-value">
        <view class="instagram-link" wx:if="{{photographerProfile.instagramHandle}}" bindtap="openInstagram">
          <image class="instagram-icon" src="{{instagramIcon}}" mode="aspectFit"></image>
          <text class="instagram-handle">@{{photographerProfile.instagramHandle}}</text>
        </view>
        <text wx:else>-</text>
      </view>
    </view>
    <view class="kv-row"><text class="kv-key">City</text><view class="kv-value"><text>{{photographerProfile.locationCity || '-'}}</text></view></view>
    <view class="kv-row"><text class="kv-key">Country</text><view class="kv-value"><text>{{photographerProfile.countryDisplay || '-'}}</text></view></view>
    <view class="kv-row"><text class="kv-key">Human Presence</text><view class="kv-value"><text class="tag-yes" wx:if="{{photographerProfile.humanPresence === 'Yes'}}">✓ Yes</text><text class="tag-no" wx:elif="{{photographerProfile.humanPresence === 'No'}}">✗ No</text><text wx:else>{{photographerProfile.humanPresence || '-'}}</text></view></view>
    <view class="kv-row"><text class="kv-key">Willing to Travel</text><view class="kv-value"><text class="tag-yes" wx:if="{{photographerProfile.willingnessToTravel === 'Yes'}}">✓ Yes</text><text class="tag-no" wx:elif="{{photographerProfile.willingnessToTravel === 'No'}}">✗ No</text><text wx:else>{{photographerProfile.willingnessToTravel || '-'}}</text></view></view>
    <view class="kv-row"><text class="kv-key">Studio Access</text><view class="kv-value"><text class="tag-yes" wx:if="{{photographerProfile.studioAccess === 'Yes'}}">✓ Yes</text><text class="tag-no" wx:elif="{{photographerProfile.studioAccess === 'No'}}">✗ No</text><text wx:else>{{photographerProfile.studioAccess || '-'}}</text></view></view>

    <view class="button-row">
      <button class="button-half secondary-btn" wx:if="{{photographerProfile.websiteUrl}}" bindtap="openWebsite">Open Portfolio</button>
      <button class="button-half primary-btn" bindtap="goToEditProfile">Edit Profile</button>
    </view>
    <view class="refresh-row">
      <button class="secondary-button refresh-row-btn" bindtap="refreshProfileData" loading="{{loadingProfile}}" disabled="{{loadingProfile}}">Refresh Profile</button>
    </view>
    <text class="error-text" wx:if="{{profileError}}">{{profileError}}</text>
  </view>
</view>
