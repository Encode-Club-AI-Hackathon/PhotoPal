.page {
  min-height: 100vh;
  width: 100%;
  padding: 48rpx 28rpx 56rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 24rpx;
  background: linear-gradient(180deg, #f2f8ff 0%, #fffdf7 100%);
  overflow-x: hidden;
}

.hero {
  width: 100%;
  max-width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: linear-gradient(135deg, #0e7490 0%, #0369a1 60%, #075985 100%);
  color: #f8fdff;
  box-shadow: 0 18rpx 44rpx rgba(7, 89, 133, 0.26);
}

.card {
  width: 100%;
  max-width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  font-size: 28rpx;
  line-height: 1.5;
  opacity: 0.95;
}

.retry-btn {
  margin-top: 16rpx;
  border-radius: 14rpx;
}

.opportunity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 100%;
}

.opportunity-card {
  width: 100%;
  max-width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(30, 41, 59, 0.1);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.card-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.business-name {
  font-size: 34rpx;
  line-height: 1.35;
  color: #0f172a;
  font-weight: 700;
}

.meta-line {
  font-size: 23rpx;
  color: #64748b;
}

.type-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ecfeff;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 45%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #f5f3ff 100%);
  border: 1rpx solid #dbeafe;
}

.match-distance,
.match-score {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.match-label {
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
}

.match-value {
  font-size: 24rpx;
  color: #0369a1;
  font-weight: 700;
}

.match-reason {
  font-size: 22rpx;
  color: #0c4a6e;
  font-style: italic;
  padding-top: 8rpx;
  border-top: 1rpx solid #bae6fd;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-label {
  width: 160rpx;
  font-size: 24rpx;
  color: #64748b;
}

.detail-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  color: #0f172a;
  word-break: break-all;
}

.map-block {
  border-radius: 16rpx;
  border: 1rpx solid #dbeafe;
  background: #f8fbff;
  padding: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.map-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.map-open-btn {
  margin: 0;
  min-width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #e0f2fe;
  color: #0c4a6e;
  border: 1rpx solid #bae6fd;
  font-size: 22rpx;
  font-weight: 600;
}

.location-map {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #e2e8f0;
}

.map-image-fallback {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  border: 1rpx dashed #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.map-fallback-text {
  font-size: 23rpx;
  color: #334155;
  text-align: center;
}

.map-hint {
  font-size: 21rpx;
  color: #0c4a6e;
  opacity: 0.8;
}

.map-fallback {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.notes-box {
  border-radius: 16rpx;
  padding: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notes-title {
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
}

.notes-text {
  font-size: 24rpx;
  color: #1e293b;
  line-height: 1.5;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.ghost-btn,
.solid-btn {
  flex: 1;
  min-width: 0;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  margin: 0;
}

.ghost-btn {
  background: #eff6ff;
  color: #1d4ed8;
  border: 1rpx solid #bfdbfe;
}

.solid-btn {
  background: #0f766e;
  color: #ffffff;
}

.contact-panel {
  border-radius: 16rpx;
  padding: 18rpx;
  background: linear-gradient(180deg, #f0fdfa 0%, #ecfeff 100%);
  border: 1rpx solid #99f6e4;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.contact-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #115e59;
}

.contact-line {
  font-size: 23rpx;
  color: #134e4a;
  word-break: break-all;
}

.contact-actions {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  margin-top: 8rpx;
}

.mini-btn {
  flex: 1;
  min-width: 0;
  border-radius: 12rpx;
  font-size: 22rpx;
  background: #ffffff;
  color: #0f766e;
  border: 1rpx solid #5eead4;
  margin: 0;
}
