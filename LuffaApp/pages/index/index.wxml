<view class="container page">
  <view class="top-links-row">
    <button class="top-link-btn" bindtap="goToSettings">
      <image class="top-link-icon" src="{{ settingsIcon }}" mode="aspectFit"></image>
      <text>Settings</text>
    </button>
    <button class="top-link-btn" bindtap="showAbout">
      <image class="top-link-icon" src="{{ infoIcon }}" mode="aspectFit"></image>
      <text>About</text>
    </button>
  </view>

  <view class="hero-card">
    <text class="brand-label">{{ title }}</text>
    <text class="welcome-title">Welcome, {{ displayName }}</text>
    <text class="welcome-subtitle">{{ subtitle }}</text>

    <view class="status-row">
      <view class="status-pill {{ walletConnected ? 'status-pill-on' : 'status-pill-off' }}">
        <text>{{ walletConnected ? "Wallet Connected" : "Wallet Not Connected" }}</text>
      </view>
      <view class="status-pill {{ hasPhotographerProfile ? 'status-pill-on' : 'status-pill-off' }}" wx:if="{{ walletConnected }}">
        <text>{{ hasPhotographerProfile ? "Profile Ready" : "Profile Needed" }}</text>
      </view>
    </view>
  </view>

  <view class="inline-loading" wx:if="{{ bootLoading || checkingProfile }}">
    <view class="spinner"></view>
    <text class="inline-loading-text">Checking your profile state...</text>
  </view>

  <view class="auth-progress-card" wx:if="{{ authPolling }}">
    <text class="auth-progress-title">Google login in progress</text>
    <text class="auth-progress-subtitle">Complete authentication in your browser and return here.</text>
    <!-- <text class="auth-progress-code" wx:if="{{ authUserCode }}">Code: {{ authUserCode }}</text> -->
    <button class="secondary-btn" wx:if="{{ authVerificationUrl }}" bindtap="copyAuthUrl">Copy Verification URL</button>
  </view>

  <view class="actions-wrap">
    <button
      class="secondary-btn action-row-btn"
      wx:if="{{ !walletConnected }}"
      bindtap="onConnectWallet"
      loading="{{ connectingWallet }}"
      disabled="{{ connectingWallet || bootLoading }}"
    >
      {{ connectingWallet ? "Connecting Wallet..." : "Connect Wallet" }}
    </button>
    <button
      class="secondary-btn action-row-btn"
      wx:if="{{ walletConnected && !hasPhotographerProfile && !checkingProfile }}"
      bindtap="goToProfileIntake"
      disabled="{{ bootLoading }}"
    >
      Complete Profile for Analysis
    </button>
    <button
      class="secondary-btn action-row-btn"
      wx:if="{{ walletConnected && hasPhotographerProfile }}"
      bindtap="goToSuggestedOpportunities"
      disabled="{{ bootLoading }}"
    >
      View Suggested Opportunities
    </button>
    <!-- <button class="secondary-btn" bindtap="fetchRecentGmailSubjects" loading="{{ loadingGmailSubjects }}" disabled="{{ loadingGmailSubjects || !auth }}">
      {{ loadingGmailSubjects ? "Fetching Gmail Subjects..." : "Get Last 5 Gmail Subjects" }}
    </button> -->
  </view>

  <view class="google-connect-card" wx:if="{{ !auth }}">
    <text class="google-connect-title">Connect Google for fast outreach</text>
    <text class="google-connect-subtitle">Send and save drafts directly from opportunities.</text>
    <button class="google-connect-btn" bindtap="handleLogin" loading="{{ authPolling }}" disabled="{{ authPolling }}">
      <image class="google-connect-icon" src="{{ googleIcon }}" mode="aspectFit"></image>
      <text>{{ authPolling ? "Waiting for approval..." : "Connect Google" }}</text>
    </button>
  </view>

  <view class="google-connected" wx:if="{{ auth }}">
    <text class="google-connected-text">Google account connected.</text>
    <button class="secondary-btn" bindtap="handleLogout">Logout</button>
  </view>
</view>
