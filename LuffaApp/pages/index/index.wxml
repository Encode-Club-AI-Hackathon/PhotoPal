<view class="container page">
  <view class="top-links-row">
    <button class="top-link-btn" bindtap="goToSettings">
      <image class="top-link-icon" src="{{settingsIcon}}" mode="aspectFit"></image>
      <text>Settings</text>
    </button>
    <button class="top-link-btn" bindtap="showAbout">
      <image class="top-link-icon" src="{{infoIcon}}" mode="aspectFit"></image>
      <text>About</text>
    </button>
  </view>

  <view class="wallet-status-row" wx:if="{{walletConnected}}">
    <image class="wallet-status-icon" src="{{tickIcon}}" mode="aspectFit"></image>
    <text class="wallet-status-title">Wallet Connected</text>
  </view>

  <view class="hero-card">
    <text class="brand-label">{{title}}</text>
    <text class="welcome-title">Welcome, {{displayName}}</text>
    <text class="welcome-subtitle">{{subtitle}}</text>
  </view>

  <view class="auth-center-wrap" wx:if="{{showAuthCenter}}">
    <button
      class="primary-btn auth-btn"
      bindtap="onConnectWallet"
      loading="{{connectingWallet}}"
      disabled="{{connectingWallet}}"
    >
      {{connectingWallet ? 'Connecting Wallet...' : 'Connect Wallet'}}
    </button>
  </view>

  <view class="actions-wrap" wx:if="{{!showAuthCenter}}">
    <button class="secondary-btn action-row-btn" wx:if="{{!walletConnected}}" bindtap="onConnectWallet" loading="{{connectingWallet}}" disabled="{{connectingWallet}}">{{connectingWallet ? 'Connecting Wallet...' : 'Connect Wallet'}}</button>
    <button class="secondary-btn action-row-btn" wx:if="{{walletConnected && !hasPhotographerProfile && !checkingProfile}}" bindtap="goToProfileIntake">Complete Profile for Analysis</button>
    <button class="secondary-btn action-row-btn" wx:if="{{walletConnected && hasPhotographerProfile}}" bindtap="goToSuggestedOpportunities">View Suggested Opportunities</button>
  </view>

  <view class="google-connect-card" wx:if="{{!loggedIn}}">
    <text class="google-connect-title">Want to seamlessly contact employers?</text>
    <text class="google-connect-subtitle">Connect your Google account to streamline outreach and follow-ups.</text>
    <button class="google-connect-btn" bindtap="handleLogin">
      <image class="google-connect-icon" src="{{googleIcon}}" mode="aspectFit"></image>
      <text>Connect</text>
    </button>
  </view>
</view>
