.page {
  min-height: 100vh;
  padding: 56rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: linear-gradient(160deg, #fff8ef 0%, #f4f7ff 100%);
  justify-content: flex-start;
}

.hero-card {
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(20, 28, 40, 0.08);
}

.top-links-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 14rpx;
}

.top-link-btn {
  flex: 1;
  height: 70rpx;
  margin: 0;
  border-radius: 14rpx;
  border: 2rpx solid #d7deec;
  background: #ffffff;
  color: #13294b;
  font-size: 26rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 16rpx;
}

.top-link-icon {
  width: 28rpx;
  height: 128rpx;
  color: #13294b;
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.brand-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #4c5a73;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #182033;
}

.welcome-subtitle {
  font-size: 28rpx;
  line-height: 1.5;
  color: #44516a;
}

.actions-wrap,
.auth-center-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.auth-center-wrap {
  width: 100%;
  max-width: 100%;
  padding: 0;
  flex-direction: row;
}

.auth-btn {
  flex: 1;
  width: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #182033;
}

.primary-btn {
  width: 100%;
  margin: 0;
  border-radius: 16rpx;
  background: #13294b;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wallet-status-row {
  width: 100%;
  border-radius: 16rpx;
  border: 2rpx solid #a9dfba;
  background: #e9f9ef;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.wallet-status-icon {
  width: 36rpx;
  height: 36rpx;
}

.wallet-status-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d6b3b;
}

.secondary-btn {
  width: 100%;
  margin: 0;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid #13294b;
  color: #13294b;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-row-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.google-connect-card {
  width: 100%;
  border-radius: 20rpx;
  border: 2rpx solid #e0e7ff;
  background: #f8faff;
  padding: 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.google-connect-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #182033;
}

.google-connect-subtitle {
  font-size: 24rpx;
  line-height: 1.5;
  color: #44516a;
}

.google-connect-btn {
  width: 100%;
  margin: 0;
  height: 84rpx;
  border-radius: 14rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  color: #13294b;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.google-connect-icon {
  width: 34rpx;
  height: 34rpx;
}