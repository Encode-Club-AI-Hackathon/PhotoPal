.page {
  min-height: 100vh;
  padding: 44rpx 26rpx 56rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  justify-content: flex-start;
  position: relative;
  overflow: hidden;
  background: #0a111d;
  color: #e8eefc;
}

button {
  font-family: inherit;
}

button::after {
  border: none;
}

button[disabled] {
  opacity: 0.6;
}

.top-links-row,
.hero-card,
.inline-loading,
.auth-progress-card,
.actions-wrap,
.google-connect-card,
.google-connected {
  position: relative;
  z-index: 1;
}

.top-links-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.top-link-btn {
  flex: 1;
  height: 74rpx;
  margin: 0;
  border-radius: 14rpx;
  border: 1rpx solid #35557d;
  background: #162235;
  color: #cfddf7;
  font-size: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 16rpx;
}

.top-link-icon {
  width: 28rpx;
  height: 28rpx;
}

.hero-card {
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #111c2e;
  border: 1rpx solid #2f4768;
  box-shadow: 0 14rpx 30rpx rgba(1, 6, 14, 0.5);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.brand-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #95aed6;
}

.welcome-title {
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #ebf3ff;
}

.welcome-subtitle {
  font-size: 27rpx;
  line-height: 1.5;
  color: #acc2e3;
}

.status-row {
  margin-top: 8rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.status-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
}

.status-pill-on {
  background: #205949;
  color: #d7fbec;
}

.status-pill-off {
  background: #3d2f3b;
  color: #f6d4e8;
}

.inline-loading {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid #35577b;
  background: #132236;
}

.spinner {
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  border: 3rpx solid #6282b8;
  border-top-color: #e3eeff;
  animation: spin 0.85s linear infinite;
}

.inline-loading-text {
  font-size: 22rpx;
  color: #c3d5f3;
}

.auth-progress-card {
  border-radius: 16rpx;
  border: 1rpx solid #4f5f2e;
  background: #252a1a;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.auth-progress-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #f8efc8;
}

.auth-progress-subtitle {
  font-size: 23rpx;
  color: #ddd7b8;
  line-height: 1.45;
}

.auth-progress-code {
  font-size: 24rpx;
  color: #f9f2ce;
  font-weight: 700;
}

.actions-wrap {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.secondary-btn {
  width: 100%;
  margin: 0;
  border-radius: 14rpx;
  background: #1a2b43;
  border: 1rpx solid #3a5a81;
  color: #d8e6ff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-row-btn {
  width: 100%;
}

.google-connect-card,
.google-connected {
  width: 100%;
  border-radius: 16rpx;
  border: 1rpx solid #3a4f6f;
  background: #131f31;
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.google-connect-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e5eeff;
}

.google-connect-subtitle {
  font-size: 24rpx;
  line-height: 1.5;
  color: #b3c5e5;
}

.google-connect-btn {
  width: 100%;
  margin: 0;
  height: 84rpx;
  border-radius: 14rpx;
  border: 1rpx solid #4c6991;
  background: #233b5f;
  color: #ebf3ff;
  font-size: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.google-connect-icon {
  width: 34rpx;
  height: 34rpx;
}

.google-connected-text {
  font-size: 24rpx;
  color: #c8daf7;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
